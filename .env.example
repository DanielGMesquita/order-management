# ========================================
# Order Management API - Environment Example
# ========================================
# Copie este arquivo para .env e configure
# com seus valores específicos
# ========================================

# ========== APLICAÇÃO ==========
NODE_ENV=development
PORT=3000

# ========== BANCO DE DADOS ==========
DB_HOST=localhost
DB_PORT=5432
DB_NAME=order_management
DB_USER=postgres
DB_PASSWORD=postgres
DB_DIALECT=postgres
DB_LOGGING=false

# ========== AUTENTICAÇÃO JWT ==========
# ⚠️  Defina uma chave secreta forte em produção!
# Use: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=24h

# ========== API ==========
API_URL=http://localhost:3000
